datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  created_at    DateTime  @default(now())
  password_hash String
  role          Role      @default(MEMBER)

  @@map("users")
}

enum Role {
  ADMIN
  MEMBER
}
